/* 编辑作品页 */
.edit-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.section { margin-bottom: 36rpx; }
.section-label { font-size: 28rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 16rpx; display: block; }
.preview-card { display: flex; align-items: center; gap: 24rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 28rpx; }
.preview-thumb { width: 112rpx; height: 112rpx; border-radius: 20rpx; flex-shrink: 0; }
.preview-info { flex: 1; }
.preview-model { font-size: 28rpx; font-weight: 700; color: #0E1F3A; display: block; }
.preview-meta { font-size: 24rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.field-input { width: 100%; background: #FBFDFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 20rpx 28rpx; font-size: 28rpx; color: #0E1F3A; box-sizing: border-box; }
.field-count { text-align: right; font-size: 22rpx; color: #8497B5; margin-top: 8rpx; display: block; }
.field-textarea { width: 100%; min-height: 160rpx; background: #FBFDFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 20rpx 28rpx; font-size: 28rpx; color: #0E1F3A; line-height: 1.6; box-sizing: border-box; }
.tag-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.tag-hint { font-size: 24rpx; color: #8497B5; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-chip { padding: 12rpx 28rpx; border-radius: 999rpx; background: #FBFDFF; font-size: 26rpx; color: #445876; border: 2rpx solid transparent; transition: all 0.2s; }
.tag-chip.active { background: linear-gradient(180deg, rgba(91,159,232,0.06) 0%, transparent 100%); color: #3B7FC8; border-color: #5B9FE8; font-weight: 600; }
.save-btn { text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 32rpx; font-weight: 700; margin-top: 16rpx; }
.save-btn:active { opacity: 0.85; }
