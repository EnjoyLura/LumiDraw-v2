<!-- 设置页 -->
<view class="settings-page">
  <!-- 账号 -->
  <view class="section-label">账号</view>
  <view class="card">
    <view class="list-row" bindtap="onEditProfile">
      <text class="lr-icon" style="color:#5B9FE8;">👤</text>
      <text class="lr-text">编辑个人资料</text>
      <text class="lr-arrow">›</text>
    </view>
    <view class="list-row" bindtap="onBindPhone">
      <text class="lr-icon" style="color:#6FD4B0;">📱</text>
      <text class="lr-text">手机号 138****8888</text>
      <text class="lr-badge">已绑定</text>
    </view>
  </view>

  <!-- 外观 -->
  <view class="section-label">外观</view>
  <view class="card">
    <view class="list-row">
      <text class="lr-icon" style="color:#5B9FE8;">☀</text>
      <text class="lr-text">深色模式</text>
      <switch checked="{{darkMode}}" bindchange="onToggleDark" color="#5B9FE8" />
    </view>
  </view>

  <!-- 关于 -->
  <view class="section-label">关于</view>
  <view class="card">
    <view class="list-row" bindtap="onAgreement">
      <text class="lr-icon">📄</text>
      <text class="lr-text">用户协议</text>
      <text class="lr-arrow">›</text>
    </view>
    <view class="list-row" bindtap="onPrivacy">
      <text class="lr-icon">🛡</text>
      <text class="lr-text">隐私政策</text>
      <text class="lr-arrow">›</text>
    </view>
    <view class="list-row" bindtap="onRechargeAgreement">
      <text class="lr-icon">💳</text>
      <text class="lr-text">充值协议</text>
      <text class="lr-arrow">›</text>
    </view>
    <view class="list-row" bindtap="onClearCache">
      <text class="lr-icon">🗑</text>
      <text class="lr-text">清除缓存</text>
      <text class="lr-extra">{{cacheSize}}</text>
      <text class="lr-arrow">›</text>
    </view>
    <view class="list-row" bindtap="onVersion">
      <text class="lr-icon">ℹ</text>
      <text class="lr-text">当前版本</text>
      <text class="lr-extra">{{version}}</text>
      <text class="lr-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="onLogout">🚪 退出登录</view>
</view>
