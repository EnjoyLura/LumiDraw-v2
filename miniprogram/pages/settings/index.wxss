/* 设置页样式 */
.settings-page { padding: 24rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.section-label { font-size: 28rpx; font-weight: 700; color: #0E1F3A; margin: 20rpx 0 16rpx; }
.card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; overflow: hidden; margin-bottom: 32rpx; }
.list-row { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 32rpx; }
.list-row:active { background: rgba(91,159,232,0.04); }
.list-row + .list-row { border-top: 1rpx solid rgba(91,159,232,0.08); }
.lr-icon { font-size: 44rpx; width: 44rpx; text-align: center; flex-shrink: 0; line-height: 1; }
.lr-text { font-size: 30rpx; color: #0E1F3A; flex: 1; }
.lr-arrow { font-size: 36rpx; color: #8497B5; flex-shrink: 0; }
.lr-extra { font-size: 24rpx; color: #8497B5; flex-shrink: 0; }
.lr-badge { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 999rpx; background: rgba(111,212,176,0.16); color: #6FD4B0; font-weight: 600; flex-shrink: 0; }
.logout-btn { width: 100%; text-align: center; padding: 24rpx 0; border-radius: 24rpx; background: #FBFDFF; border: 2rpx solid rgba(91,159,232,0.14); color: #FFA8B8; font-size: 30rpx; margin-top: 16rpx; }
.logout-btn:active { background: rgba(255,168,184,0.06); }

