/* 关注列表 */
.follow-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.user-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 0; }
.user-item + .user-item { border-top: 1rpx solid rgba(91,159,232,0.08); }
.user-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 32rpx; font-weight: 700; flex-shrink: 0; }
.user-info { flex: 1; min-width: 0; }
.user-name { font-size: 30rpx; font-weight: 600; color: #0E1F3A; display: block; }
.user-bio { font-size: 24rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.follow-btn { padding: 10rpx 28rpx; border-radius: 999rpx; background: rgba(91,159,232,0.12); color: #5B9FE8; font-size: 26rpx; font-weight: 600; flex-shrink: 0; }
.follow-btn.following { background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.14); color: #8497B5; }
