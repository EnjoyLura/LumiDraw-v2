/* 积分充值页 */
.recharge-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.balance-card { background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); border-radius: 28rpx; padding: 40rpx 32rpx; margin-bottom: 32rpx; position: relative; overflow: hidden; }
.balance-label { font-size: 26rpx; color: rgba(255,255,255,0.75); display: block; margin-bottom: 16rpx; }
.balance-num { font-size: 64rpx; font-weight: 700; color: white; }
.section-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; }
.tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; margin-bottom: 24rpx; }
.tier-card { background: #FFFFFF; border: 4rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx 16rpx; text-align: center; position: relative; overflow: hidden; transition: all 0.2s; }
.tier-card.selected { border-color: #5B9FE8; background: rgba(91,159,232,0.06); }
.tier-badge { position: absolute; top: 8rpx; right: 8rpx; font-size: 18rpx; font-weight: 700; padding: 2rpx 12rpx; border-radius: 999rpx; background: rgba(91,159,232,0.12); color: #5B9FE8; }
.tier-credits { font-size: 40rpx; font-weight: 700; color: #5B9FE8; display: block; }
.tier-unit { font-size: 22rpx; color: #8497B5; display: block; }
.tier-bonus { font-size: 20rpx; color: #6FD4B0; font-weight: 600; display: block; margin: 6rpx 0; }
.tier-bonus-spacer { height: 34rpx; }
.tier-price { font-size: 28rpx; font-weight: 700; color: #0E1F3A; margin-top: 8rpx; display: block; }
.tier-card.custom { border-style: dashed; border-color: rgba(91,159,232,0.32); display: flex; flex-direction: column; align-items: center; justify-content: center; }
.custom-icon { font-size: 44rpx; color: #5B9FE8; }
.custom-text { font-size: 26rpx; font-weight: 600; color: #5B9FE8; }
.custom-sub { font-size: 22rpx; color: #8497B5; margin-top: 4rpx; }
.recharge-btn { text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 30rpx; font-weight: 700; margin-bottom: 32rpx; }
.recharge-btn:active { opacity: 0.85; }
.record-tabs { display: flex; background: rgba(91,159,232,0.08); border-radius: 24rpx; padding: 8rpx; margin-bottom: 20rpx; }
.record-tab { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 20rpx; font-size: 26rpx; font-weight: 600; color: #445876; transition: all 0.3s; }
.record-tab.active { background: #FFFFFF; color: #5B9FE8; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.record-list { background: #FFFFFF; border-radius: 28rpx; border: 1rpx solid rgba(91,159,232,0.14); overflow: hidden; }
.record-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 28rpx; }
.record-item + .record-item { border-top: 1rpx solid rgba(91,159,232,0.08); }
.record-icon { width: 64rpx; height: 64rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 700; flex-shrink: 0; }
.record-icon.earn { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.record-icon.spend { background: rgba(255,168,184,0.22); color: #FFA8B8; }
.record-info { flex: 1; min-width: 0; }
.record-title { font-size: 28rpx; font-weight: 600; color: #0E1F3A; display: block; }
.record-meta { font-size: 22rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.record-amount { font-size: 28rpx; font-weight: 700; flex-shrink: 0; }
.record-amount.earn { color: #6FD4B0; }
.record-amount.spend { color: #FFA8B8; }
.custom-sheet { padding: 8rpx 40rpx 48rpx; }
.sheet-title { font-size: 36rpx; font-weight: 700; color: #0E1F3A; text-align: center; margin-bottom: 40rpx; }
.custom-input-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 16rpx; }
.custom-yen { font-size: 48rpx; font-weight: 700; color: #5B9FE8; }
.custom-input { flex: 1; font-size: 36rpx; font-weight: 600; height: 96rpx; padding: 0 24rpx; background: #FBFDFF; border: 3rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; color: #0E1F3A; box-sizing: border-box; transition: border-color 0.3s, box-shadow 0.3s; }
.custom-input.focused { border-color: #5B9FE8; box-shadow: 0 0 0 6rpx rgba(91,159,232,0.12); }
.custom-hint { font-size: 22rpx; color: #8497B5; margin-bottom: 28rpx; }
.custom-preview { background: rgba(91,159,232,0.06); border: 2rpx solid rgba(91,159,232,0.10); border-radius: 24rpx; padding: 28rpx; margin-bottom: 32rpx; }
.cp-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.cp-row:last-child { margin-bottom: 0; }
.cp-label { font-size: 26rpx; color: #445876; }
.cp-num { font-size: 36rpx; font-weight: 700; color: #5B9FE8; }
.cp-bonus { font-size: 28rpx; font-weight: 600; color: #6FD4B0; }
.custom-actions { display: flex; gap: 20rpx; }
.custom-cancel { flex: 1; text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.32); font-size: 30rpx; font-weight: 600; color: #0E1F3A; }
.custom-cancel:active { background: rgba(91,159,232,0.06); }
.custom-confirm { flex: 1; text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 30rpx; font-weight: 700; }
.custom-confirm:active { opacity: 0.85; }
