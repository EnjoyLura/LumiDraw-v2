/* 首页样式 */
.home-scroll {
  height: 100vh;
}

/* ============ Banner ============ */
.banner-wrap {
  position: relative;
  margin: 0 32rpx 32rpx;
}

.banner-swiper {
  height: 300rpx;
  border-radius: 40rpx;
  overflow: hidden;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 40rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.banner-big-text {
  position: absolute;
  bottom: 40rpx;
  left: 32rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  z-index: 2;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.4));
  z-index: 1;
}

.banner-btn {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  color: white;
  border-radius: 999rpx;
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 自定义指示点 */
.banner-dots {
  position: absolute;
  bottom: 16rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.banner-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(91, 159, 232, 0.3);
  transition: all 0.3s;
}

.banner-dot.active {
  width: 40rpx;
  border-radius: 6rpx;
  background: #5B9FE8;
}

/* ============ 区块标题 ============ */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0E1F3A;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #5B9FE8;
  font-size: 28rpx;
  font-weight: 600;
}

.more-text {
  color: #5B9FE8;
}

.more-arrow {
  color: #5B9FE8;
  font-size: 36rpx;
  line-height: 1;
}

/* ============ 热门玩法 ============ */
.gameplay-scroll {
  white-space: nowrap;
  margin-bottom: 36rpx;
}

.gameplay-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.gameplay-item {
  flex-shrink: 0;
  cursor: pointer;
  text-align: center;
}

.gameplay-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.gameplay-img {
  width: 100%;
  height: 100%;
}

.gameplay-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #B8A5E3 0%, #5B9FE8 50%, #6FD4B0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: 700;
}

.gameplay-name {
  font-size: 22rpx;
  color: #445876;
  display: block;
  white-space: nowrap;
  text-align: center;
}

/* ============ Tab切换 ============ */
.tab-switcher {
  display: inline-flex;
  gap: 32rpx;
  position: relative;
  align-items: center;
}

.tab-item {
  font-size: 28rpx;
  font-weight: 500;
  color: #8497B5;
  padding-bottom: 12rpx;
  position: relative;
  transition: color 0.3s;
  flex-shrink: 0;
  line-height: 1;
}

.tab-item.active {
  font-weight: 700;
  color: #5B9FE8;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #5B9FE8;
}

/* ============ 瀑布流 ============ */
.waterfall-wrap {
  padding: 0 24rpx;
  position: relative;
  min-height: 200rpx;
}

/* Tab切换加载 spinner */
.tab-loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.tab-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(91, 159, 232, 0.15);
  border-top-color: #5B9FE8;
  border-radius: 50%;
  animation: tabSpin 0.7s linear infinite;
}

@keyframes tabSpin {
  to { transform: rotate(360deg); }
}

/* 瀑布流滑动动画 */
@keyframes wfSlideLeft {
  from { opacity: 0; transform: translateX(-60rpx); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes wfSlideRight {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.wf-slide-left {
  animation: wfSlideLeft 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.wf-slide-right {
  animation: wfSlideRight 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

/* ============ 长按菜单 ============ */
.long-press-grid {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 32rpx 48rpx;
}

.lp-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0;
}

.lp-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lp-label {
  font-size: 24rpx;
  color: #445876;
}

