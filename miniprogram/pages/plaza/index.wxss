/* 广场页样式 */
.plaza-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ============ 顶部栏 ============ */
.plaza-topbar {
  display: flex;
  align-items: center;
  padding: 8rpx 32rpx;
  gap: 20rpx;
  flex-shrink: 0;
}

.topbar-btn {
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.topbar-icon {
  font-size: 44rpx;
  color: #0E1F3A;
  line-height: 1;
}

.search-icon {
  font-size: 48rpx;
}

.topbar-tabs {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 56rpx;
  position: relative;
  padding-bottom: 8rpx;
}

.topbar-tab {
  font-size: 32rpx;
  font-weight: 500;
  color: #8497B5;
  position: relative;
  padding-bottom: 8rpx;
  transition: color 0.3s;
}

.topbar-tab.active {
  font-weight: 700;
  color: #5B9FE8;
}

.topbar-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #5B9FE8;
}

/* ============ 分类栏 ============ */
.category-bar {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.category-scroll-wrap {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-width: 0;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 0 16rpx;
}

.category-chip {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 28rpx;
  font-weight: 400;
  color: #445876;
  transition: all 0.3s;
}

.category-chip.active {
  font-weight: 600;
  color: #5B9FE8;
}

.category-fade {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 60rpx;
  background: linear-gradient(to right, transparent, #EEF4FC);
  pointer-events: none;
}

.filter-btn {
  width: 88rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-left: 1rpx solid rgba(91, 159, 232, 0.14);
}

/* CSS 筛选图标（三条横线） */
.filter-icon-lines {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.filter-line {
  width: 32rpx;
  height: 3rpx;
  background: #0E1F3A;
  border-radius: 2rpx;
}

.filter-line.short {
  width: 22rpx;
}

/* ============ 瀑布流区域 ============ */
.plaza-scroll {
  flex: 1;
  height: 0;
}

.waterfall-area {
  padding: 0 24rpx;
  position: relative;
  min-height: 200rpx;
}

/* Tab切换加载 spinner */
.tab-loading {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.tab-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(91, 159, 232, 0.15);
  border-top-color: #5B9FE8;
  border-radius: 50%;
  animation: tabSpin 0.7s linear infinite;
}

@keyframes tabSpin {
  to { transform: rotate(360deg); }
}

/* 瀑布流滑动动画 */
@keyframes wfSlideLeft {
  from { opacity: 0; transform: translateX(-60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes wfSlideRight {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.wf-slide-left {
  animation: wfSlideLeft 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.wf-slide-right {
  animation: wfSlideRight 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

/* ============ 左抽屉 ============ */
.drawer-header {
  padding: 180rpx 40rpx 0;
  background: linear-gradient(180deg, #E1EBF8 0%, #F5F9FE 100%);
  border-bottom: 1rpx solid rgba(91, 159, 232, 0.14);
  padding-bottom: 48rpx;
}

.drawer-user-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 40rpx;
}

.drawer-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B9FE8, #6FD4B0);
  color: white;
  font-weight: 700;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.drawer-user-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.drawer-user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #0E1F3A;
}

.drawer-credits {
  font-size: 32rpx;
  color: #8497B5;
}

.credits-num {
  color: #5B9FE8;
  font-weight: 700;
}

.credits-label {
  color: #8497B5;
}

.drawer-quick {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.drawer-quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.dq-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dq-icon-text {
  color: white;
  font-size: 36rpx;
  line-height: 1;
}

.dq-text {
  font-size: 24rpx;
  color: #445876;
}

.drawer-menu {
  padding: 24rpx 0;
  flex: 1;
}

.drawer-menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 40rpx;
  position: relative;
}

.drawer-menu-item:active {
  background: rgba(91, 159, 232, 0.06);
}

.dm-icon {
  font-size: 44rpx;
  width: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.dm-text {
  font-size: 30rpx;
  color: #0E1F3A;
  flex: 1;
}

.dm-arrow {
  font-size: 36rpx;
  color: #8497B5;
  flex-shrink: 0;
}

.dm-badge {
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #FFA8B8;
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  flex-shrink: 0;
}

/* ============ 筛选抽屉 ============ */
.filter-sheet {
  padding: 16rpx 40rpx 48rpx;
}

.filter-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0E1F3A;
  margin: 28rpx 0 20rpx;
}

.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.filter-chip {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  background: transparent;
  border: 1rpx solid rgba(91, 159, 232, 0.32);
  color: #445876;
  transition: all 0.3s;
}

.filter-chip.active {
  background: rgba(91, 159, 232, 0.12);
  border-color: #5B9FE8;
  color: #3B7FC8;
  font-weight: 600;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.filter-btn-reset {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0E1F3A;
  background: #FFFFFF;
  border: 1rpx solid rgba(91, 159, 232, 0.32);
}

.filter-btn-reset:active {
  background: rgba(91, 159, 232, 0.06);
}

.filter-btn-apply {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #5B9FE8 0%, #7BC4F0 45%, #6FD4B0 100%);
}

.filter-btn-apply:active {
  opacity: 0.85;
}

