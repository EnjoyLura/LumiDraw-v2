<!-- 会员中心页 -->
<nav-bar title="会员中心" back />
<view class="member-page">
  <!-- 会员卡 -->
  <view class="vip-card">
    <view class="vip-header">
      <view class="vip-icon">♛</view>
      <view class="vip-info">
        <text class="vip-title">Lumi 会员</text>
        <text class="vip-desc">每天自动领取积分，畅享AI创作</text>
      </view>
    </view>
    <view class="vip-stats">
      <view class="vip-stat"><text class="vs-num">50</text><text class="vs-label">每日积分</text></view>
      <view class="vip-stat"><text class="vs-num">×2</text><text class="vs-label">签到加成</text></view>
      <view class="vip-stat"><text class="vs-num">优先</text><text class="vs-label">生成队列</text></view>
    </view>
  </view>

  <!-- 套餐选择 -->
  <view class="section-title">选择套餐</view>
  <view class="plan-list">
    <view wx:for="{{plans}}" wx:key="name"
      class="plan-card {{selectedPlan === index ? 'selected' : ''}}"
      data-index="{{index}}" bindtap="onSelectPlan">
      <view wx:if="{{item.recommend}}" class="plan-badge">推荐</view>
      <view class="plan-left">
        <view class="plan-name-row">
          <text class="plan-name">{{item.name}}</text>
          <text wx:if="{{item.name === '季卡'}}" class="plan-save">省¥6</text>
          <text wx:if="{{item.name === '年卡'}}" class="plan-save">省¥48</text>
        </view>
        <text class="plan-desc">每日领取50积分 · 共{{item.dailyCredits * item.days}}积分</text>
      </view>
      <view class="plan-right">
        <text class="plan-price">¥{{item.price}}</text>
        <text class="plan-daily">¥{{item.days === 30 ? '0.6' : item.days === 90 ? '0.53' : '0.46'}}/天</text>
      </view>
    </view>
  </view>

  <!-- 开通按钮 -->
  <view class="subscribe-btn" bindtap="onSubscribe">
    <text>♛ 立即开通 · ¥{{plans[selectedPlan].price}}</text>
  </view>

  <!-- 会员权益 -->
  <view class="section-title">会员权益</view>
  <view class="benefit-grid">
    <view wx:for="{{benefits}}" wx:key="title" class="benefit-card">
      <view class="benefit-icon" style="background: {{item.color}}22;">
        <text style="font-size: 32rpx;">{{item.icon}}</text>
      </view>
      <view class="benefit-info">
        <text class="benefit-title">{{item.title}}</text>
        <text class="benefit-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="agreement-text">
    <text>开通即表示同意 </text>
    <text class="agreement-link">《会员服务协议》</text>
  </view>
</view>
