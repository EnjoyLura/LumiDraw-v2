/* 会员中心页 */
.member-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.vip-card { background: linear-gradient(135deg, #1a1a2e, #16213e 40%, #0f3460); border-radius: 28rpx; padding: 48rpx 32rpx; margin-bottom: 32rpx; position: relative; overflow: hidden; }
.vip-header { display: flex; align-items: center; gap: 24rpx; margin-bottom: 32rpx; }
.vip-icon { width: 88rpx; height: 88rpx; border-radius: 50%; background: linear-gradient(135deg, #B8A5E3, #FFD700); display: flex; align-items: center; justify-content: center; font-size: 44rpx; color: #1a1a2e; }
.vip-title { font-size: 40rpx; font-weight: 700; color: white; display: block; }
.vip-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; margin-top: 4rpx; }
.vip-stats { display: flex; gap: 24rpx; }
.vip-stat { flex: 1; text-align: center; padding: 20rpx 0; background: rgba(255,255,255,0.06); border-radius: 20rpx; }
.vs-num { font-size: 40rpx; font-weight: 700; color: #FFD700; display: block; }
.vs-label { font-size: 20rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 4rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; }
.plan-list { display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 24rpx; }
.plan-card { display: flex; align-items: center; background: #FFFFFF; border: 4rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 28rpx; position: relative; overflow: hidden; transition: all 0.2s; }
.plan-card.selected { border-color: #5B9FE8; background: linear-gradient(180deg, rgba(91,159,232,0.06) 0%, transparent 100%); }
.plan-badge { position: absolute; top: 0; right: 0; background: #5B9FE8; color: white; font-size: 18rpx; font-weight: 700; padding: 6rpx 20rpx; border-radius: 0 0 0 20rpx; }
.plan-left { flex: 1; min-width: 0; }
.plan-name-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 4rpx; }
.plan-name { font-size: 30rpx; font-weight: 700; color: #0E1F3A; }
.plan-save { font-size: 20rpx; font-weight: 600; padding: 2rpx 12rpx; border-radius: 999rpx; background: rgba(111,212,176,0.16); color: #6FD4B0; }
.plan-desc { font-size: 24rpx; color: #8497B5; display: block; }
.plan-right { text-align: right; flex-shrink: 0; }
.plan-price { font-size: 40rpx; font-weight: 700; color: #0E1F3A; display: block; }
.plan-daily { font-size: 20rpx; color: #8497B5; display: block; }
.subscribe-btn { text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 32rpx; font-weight: 700; margin-bottom: 32rpx; }
.subscribe-btn:active { opacity: 0.85; }
.benefit-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; margin-bottom: 32rpx; }
.benefit-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 28rpx; display: flex; align-items: flex-start; gap: 20rpx; }
.benefit-icon { width: 64rpx; height: 64rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.benefit-title { font-size: 26rpx; font-weight: 700; color: #0E1F3A; display: block; }
.benefit-desc { font-size: 22rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.agreement-text { text-align: center; font-size: 22rpx; color: #8497B5; padding: 16rpx 0; }
.agreement-link { color: #5B9FE8; }
