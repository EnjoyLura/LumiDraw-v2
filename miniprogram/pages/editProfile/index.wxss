/* 编辑资料页样式 */
.edit-page { padding: 48rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.avatar-section { text-align: center; margin-bottom: 48rpx; position: relative; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: white; font-size: 64rpx; font-weight: 700; }
.avatar-camera { position: absolute; bottom: 40rpx; right: calc(50% - 80rpx - 10rpx); width: 56rpx; height: 56rpx; border-radius: 50%; background: #5B9FE8; display: flex; align-items: center; justify-content: center; border: 4rpx solid #EEF4FC; font-size: 28rpx; }
.avatar-hint { display: block; font-size: 24rpx; color: #8497B5; margin-top: 12rpx; }
.field { margin-bottom: 40rpx; }
.field-label { font-size: 26rpx; font-weight: 600; color: #445876; margin-bottom: 12rpx; display: block; }
.field-input { width: 100%; height: 88rpx; background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 0 28rpx; font-size: 28rpx; color: #0E1F3A; box-sizing: border-box; transition: border-color 0.3s, box-shadow 0.3s; }
.field-input.focused { border-color: #5B9FE8; box-shadow: none; }
.field-input.disabled { opacity: 0.6; }
.field-count { text-align: right; font-size: 22rpx; color: #8497B5; margin-top: 8rpx; display: block; }
.field-textarea { width: 100%; min-height: 200rpx; background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx 28rpx; font-size: 28rpx; color: #0E1F3A; line-height: 1.6; box-sizing: border-box; transition: border-color 0.3s, box-shadow 0.3s; }
.field-textarea.focused { border-color: #5B9FE8; box-shadow: none; }
.field-locked { display: flex; align-items: center; gap: 12rpx; }
.field-locked .field-input { flex: 1; min-width: 0; }
.lock-icon { font-size: 32rpx; flex-shrink: 0; }
.field-hint { font-size: 22rpx; color: #8497B5; margin-top: 8rpx; display: block; }
.gender-row { display: flex; gap: 20rpx; }
.gender-opt { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 20rpx; font-size: 26rpx; font-weight: 600; border: 4rpx solid rgba(91,159,232,0.14); background: #FFFFFF; color: #445876; transition: all 0.3s; }
.gender-opt.active { border-color: #5B9FE8; background: rgba(91,159,232,0.12); color: #3B7FC8; }
.save-btn { width: 100%; text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: #5B9FE8; color: white; font-size: 30rpx; font-weight: 700; margin-top: 16rpx; }
.save-btn:active { background: #4A8FD8; }
