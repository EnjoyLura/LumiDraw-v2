/* 管理后台首页 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.page-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; display: block; }
.stat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-bottom: 32rpx; }
.stat-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx; }
.stat-card:active { background: rgba(91,159,232,0.04); }
.sc-label { font-size: 24rpx; color: #8497B5; display: block; }
.sc-value { font-size: 48rpx; font-weight: 700; color: #0E1F3A; display: block; margin: 8rpx 0; }
.sc-change { font-size: 22rpx; display: block; }
.menu-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; overflow: hidden; margin-bottom: 32rpx; }
.menu-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 28rpx; }
.menu-item:active { background: rgba(91,159,232,0.04); }
.menu-item + .menu-item { border-top: 1rpx solid rgba(91,159,232,0.08); }
.mi-icon { font-size: 40rpx; width: 44rpx; text-align: center; flex-shrink: 0; }
.mi-label { font-size: 30rpx; color: #0E1F3A; flex: 1; }
.mi-count { font-size: 24rpx; color: #8497B5; flex-shrink: 0; }
.mi-badge { min-width: 36rpx; height: 36rpx; border-radius: 999rpx; background: #FF6B8A; color: white; font-size: 20rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; flex-shrink: 0; }
.mi-arrow { font-size: 36rpx; color: #8497B5; flex-shrink: 0; }
