<!-- 用户统计 -->
<view class="admin-page">
  <text class="page-title">用户统计</text>
  <view class="stat-row"><view wx:for="{{stats}}" wx:key="label" class="mini-stat"><text class="ms-num">{{item.value}}</text><text class="ms-label">{{item.label}}</text></view></view>
  <text class="section-title">近7日新增用户</text>
  <view class="bar-chart"><view class="bar-row"><view wx:for="{{bars}}" wx:key="label" class="bar-col"><view class="bar-fill" style="height: {{item.h}}%;"></view><text class="bar-label">{{item.label}}</text></view></view></view>
  <text class="section-title">用户构成</text>
  <view class="list-card"><view wx:for="{{segments}}" wx:key="label" class="list-item"><text class="li-label">{{item.label}}</text><text class="li-value">{{item.value}} ({{item.pct}})</text></view></view>
  <text class="section-title">关键指标</text>
  <view class="list-card"><view wx:for="{{metrics}}" wx:key="label" class="list-item"><text class="li-label">{{item.label}}</text><text class="li-value">{{item.value}}</text></view></view>
</view>