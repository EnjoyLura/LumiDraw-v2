/* 模型管理 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.count-text { font-size: 26rpx; color: #8497B5; }
.add-btn { padding: 10rpx 28rpx; border-radius: 999rpx; background: #5B9FE8; color: white; font-size: 24rpx; font-weight: 600; }

.model-card { display: flex; align-items: center; gap: 20rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx; margin-bottom: 16rpx; }
.mc-cover { width: 112rpx; height: 112rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.mc-cover-text { color: white; font-size: 40rpx; font-weight: 700; }
.mc-info { flex: 1; min-width: 0; }
.mc-name-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 4rpx; }
.mc-name { font-size: 28rpx; font-weight: 700; color: #0E1F3A; }
.mc-badge { font-size: 18rpx; font-weight: 600; padding: 2rpx 10rpx; border-radius: 8rpx; }
.mc-desc { font-size: 22rpx; color: #8497B5; display: block; margin-bottom: 8rpx; }
.mc-tags { display: flex; gap: 8rpx; }
.mc-tag { font-size: 18rpx; padding: 4rpx 10rpx; border-radius: 999rpx; background: rgba(91,159,232,0.12); color: #3B7FC8; }
.mc-right { display: flex; flex-direction: column; align-items: center; gap: 4rpx; flex-shrink: 0; }
.mc-cost { font-size: 32rpx; font-weight: 700; color: #5B9FE8; }
.mc-unit { font-size: 20rpx; color: #8497B5; }
.mc-ops { display: flex; align-items: center; gap: 8rpx; margin-top: 8rpx; }
.mc-edit-btn { width: 48rpx; height: 48rpx; border-radius: 12rpx; background: rgba(91,159,232,0.12); color: #5B9FE8; font-size: 28rpx; display: flex; align-items: center; justify-content: center; }
