<!-- 举报队列 -->
<view class="admin-page">
  <text class="page-title">举报队列</text>
  <view class="stat-row">
    <view class="mini-stat"><text class="ms-num" style="color:#FFA8B8;">3</text><text class="ms-label">待处理</text></view>
    <view class="mini-stat"><text class="ms-num" style="color:#6FD4B0;">4</text><text class="ms-label">已处理</text></view>
    <view class="mini-stat"><text class="ms-num">1</text><text class="ms-label">已驳回</text></view>
  </view>
  <view class="list-card">
    <view wx:for="{{reports}}" wx:key="id" class="list-item" data-id="{{item.id}}" bindtap="onDetail">
      <view class="li-info"><text class="li-title">{{item.title}}</text><text class="li-sub">{{item.reporter}} · {{item.reason}} · {{item.time}}</text></view>
      <text class="li-badge {{item.status === '待处理' ? 'badge-red' : 'badge-green'}}">{{item.status}}</text>
      <text class="li-arrow">›</text>
    </view>
  </view>
</view>