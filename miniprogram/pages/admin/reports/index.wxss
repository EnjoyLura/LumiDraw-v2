/* 举报队列 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.stat-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.mini-stat { flex: 1; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 20rpx; padding: 20rpx; text-align: center; }
.ms-num { font-size: 40rpx; font-weight: 700; color: #0E1F3A; display: block; }
.ms-label { font-size: 22rpx; color: #8497B5; }

.filter-row { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.filter-tab { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 16rpx; font-size: 24rpx; font-weight: 600; background: rgba(91,159,232,0.06); color: #445876; }
.filter-tab.active { background: #5B9FE8; color: white; }

.report-card { display: flex; align-items: center; gap: 20rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 20rpx; padding: 20rpx; margin-bottom: 12rpx; }
.rp-thumb { width: 96rpx; height: 96rpx; border-radius: 16rpx; flex-shrink: 0; }
.rp-info { flex: 1; min-width: 0; }
.rp-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6rpx; }
.rp-title { font-size: 28rpx; font-weight: 600; color: #0E1F3A; }
.rp-status { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx; font-weight: 600; }
.status-red { background: rgba(255,168,184,0.22); color: #FFA8B8; }
.status-green { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.status-gray { background: rgba(132,151,181,0.16); color: #8497B5; }
.rp-meta { font-size: 22rpx; color: #8497B5; display: block; }
.rp-arrow { font-size: 32rpx; color: #8497B5; flex-shrink: 0; }
