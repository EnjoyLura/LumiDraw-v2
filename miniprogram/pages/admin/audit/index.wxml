<!-- 审核设置 -->
<nav-bar title="审核设置" back />
<view class="admin-page">
  <text class="page-title">审核设置</text>
  <text class="section-title">自动审核</text>
  <view class="list-card"><view wx:for="{{autoSettings}}" wx:key="title" class="switch-row" data-idx="{{index}}" bindtap="onToggle"><view class="sr-info"><text class="sr-title">{{item.title}}</text><text class="sr-desc">{{item.desc}}</text></view><switch checked="{{item.enabled}}" color="#5B9FE8" /></view></view>
  <text class="section-title">人工审核</text>
  <view class="list-card"><view wx:for="{{manualSettings}}" wx:key="title" class="switch-row" data-idx="{{index}}" bindtap="onToggle"><view class="sr-info"><text class="sr-title">{{item.title}}</text><text class="sr-desc">{{item.desc}}</text></view><switch checked="{{item.enabled}}" color="#5B9FE8" /></view></view>
  <text class="section-title">审核阈值</text>
  <view class="list-card"><view wx:for="{{thresholds}}" wx:key="label" class="list-item"><text class="li-label">{{item.label}}</text><text class="li-value">{{item.value}}</text></view></view>
  <text class="section-title">通知设置</text>
  <view class="list-card"><view wx:for="{{notifySettings}}" wx:key="title" class="switch-row" data-idx="{{index}}" bindtap="onToggle"><view class="sr-info"><text class="sr-title">{{item.title}}</text><text class="sr-desc">{{item.desc}}</text></view><switch checked="{{item.enabled}}" color="#5B9FE8" /></view></view>
</view>