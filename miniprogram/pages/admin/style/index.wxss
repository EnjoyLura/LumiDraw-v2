/* 风格管理 */
.admin-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.page-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 24rpx; display: block; }

.style-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.style-item { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 20rpx; overflow: hidden; }
.style-item:active { opacity: 0.8; }
.style-cover { width: 100%; aspect-ratio: 1; }
.style-name { font-size: 24rpx; font-weight: 600; color: #0E1F3A; text-align: center; padding: 12rpx 8rpx; display: block; }