<!-- 风格管理 -->
<nav-bar title="风格管理" back />
<view class="admin-page">
  <view class="header-row"><text class="page-title">风格管理</text><view class="add-btn" bindtap="onAdd">+ 新增</view></view>
  <view class="style-grid">
    <view wx:for="{{styles}}" wx:key="index" class="style-item" data-idx="{{item.index}}" bindtap="onEdit">
      <view class="style-cover" style="background: linear-gradient(135deg, hsl({{item.index * 24}}, 60%, 70%), hsl({{item.index * 24 + 60}}, 50%, 60%));"></view>
      <text class="style-name">{{item.name}}</text>
    </view>
  </view>
</view>