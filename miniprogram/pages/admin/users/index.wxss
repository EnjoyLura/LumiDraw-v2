/* 用户列表 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }

.search-box { display: flex; align-items: center; gap: 12rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 0 24rpx; margin-bottom: 24rpx; }
.search-icon { font-size: 36rpx; color: #8497B5; flex-shrink: 0; }
.search-input { flex: 1; height: 80rpx; font-size: 28rpx; color: #0E1F3A; }

.user-card { display: flex; align-items: center; gap: 20rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 20rpx; padding: 20rpx; margin-bottom: 12rpx; }
.uc-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 32rpx; font-weight: 700; flex-shrink: 0; }
.uc-info { flex: 1; min-width: 0; }
.uc-name { font-size: 28rpx; font-weight: 600; color: #0E1F3A; display: block; }
.uc-meta { font-size: 22rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.uc-badge { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 999rpx; font-weight: 600; flex-shrink: 0; margin-left: 4rpx; }
.badge-vip { background: rgba(255,215,0,0.15); color: #C89520; }
.badge-ok { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.badge-ban { background: rgba(255,168,184,0.22); color: #FFA8B8; }
.uc-arrow { font-size: 32rpx; color: #8497B5; flex-shrink: 0; }
