/* 玩法管理 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.count-text { font-size: 26rpx; color: #8497B5; }
.add-btn { padding: 10rpx 28rpx; border-radius: 999rpx; background: #5B9FE8; color: white; font-size: 24rpx; font-weight: 600; }

.gp-card { display: flex; align-items: center; gap: 20rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx; margin-bottom: 16rpx; }
.gp-cover { width: 112rpx; height: 112rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.gp-cover-text { color: white; font-size: 40rpx; font-weight: 700; }
.gp-info { flex: 1; min-width: 0; }
.gp-name { font-size: 28rpx; font-weight: 700; color: #0E1F3A; display: block; margin-bottom: 6rpx; }
.gp-meta { display: flex; gap: 16rpx; font-size: 22rpx; color: #8497B5; }
.gp-ops { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.gp-edit { width: 48rpx; height: 48rpx; border-radius: 12rpx; background: rgba(91,159,232,0.12); color: #5B9FE8; font-size: 28rpx; display: flex; align-items: center; justify-content: center; }
