<!-- 生成统计 -->
<view class="admin-page">
  <text class="page-title">生成统计</text>
  <view class="stat-row"><view wx:for="{{stats}}" wx:key="label" class="mini-stat"><text class="ms-num">{{item.value}}</text><text class="ms-label">{{item.label}}</text></view></view>
  <text class="section-title">近7日生成量</text>
  <view class="bar-chart"><view class="bar-row"><view wx:for="{{bars}}" wx:key="label" class="bar-col"><view class="bar-fill" style="height: {{item.h}}%;background: #B8A5E3;"></view><text class="bar-label">{{item.label}}</text></view></view></view>
  <text class="section-title">模型使用分布</text>
  <view class="list-card" style="padding:24rpx;"><view wx:for="{{models}}" wx:key="name" class="progress-row"><view class="pr-label"><text>{{item.name}}</text><text>{{item.count}}</text></view><view class="pr-bar"><view class="pr-fill" style="width: {{item.pct * 2.5}}%;background: {{item.color}};"></view></view></view></view>
  <text class="section-title">性能指标</text>
  <view class="list-card"><view wx:for="{{metrics}}" wx:key="label" class="list-item"><text class="li-label">{{item.label}}</text><text class="li-value">{{item.value}}</text></view></view>
</view>