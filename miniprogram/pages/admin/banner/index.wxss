/* Banner管理 */
.admin-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.count-text { font-size: 26rpx; color: #8497B5; }
.add-btn { padding: 10rpx 28rpx; border-radius: 999rpx; background: #5B9FE8; color: white; font-size: 24rpx; font-weight: 600; }
.add-btn:active { opacity: 0.85; }

/* Banner卡片 */
.banner-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; overflow: hidden; margin-bottom: 20rpx; }
.bc-cover { width: 100%; height: 200rpx; }
.bc-body { padding: 24rpx; }
.bc-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.bc-title { font-size: 30rpx; font-weight: 700; color: #0E1F3A; }
.bc-status { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 999rpx; font-weight: 600; }
.status-green { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.status-gray { background: rgba(132,151,181,0.16); color: #8497B5; }
.bc-meta { display: flex; flex-wrap: wrap; gap: 20rpx; font-size: 22rpx; color: #8497B5; margin-bottom: 20rpx; }
.bc-actions { display: flex; gap: 12rpx; }
.bc-btn { flex: 1; text-align: center; padding: 14rpx 0; border-radius: 16rpx; font-size: 24rpx; font-weight: 600; }
.bc-btn:active { opacity: 0.85; }
.bc-btn-edit { background: rgba(91,159,232,0.12); color: #5B9FE8; }
.bc-btn-off { background: rgba(132,151,181,0.12); color: #445876; }
.bc-btn-on { background: rgba(91,159,232,0.12); color: #5B9FE8; }
.bc-btn-del { background: rgba(255,168,184,0.15); color: #FFA8B8; flex: 0; padding: 14rpx 24rpx; }
