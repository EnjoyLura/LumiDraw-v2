<!-- 作品管理 -->
<nav-bar title="作品管理" back />
<view class="admin-page">
  <text class="page-title">作品管理</text>
  <view class="stat-row">
    <view class="mini-stat"><text class="ms-num">22</text><text class="ms-label">全部</text></view>
    <view class="mini-stat"><text class="ms-num">18</text><text class="ms-label">已发布</text></view>
    <view class="mini-stat"><text class="ms-num">4</text><text class="ms-label">未发布</text></view>
  </view>
  <view class="list-card">
    <view wx:for="{{works}}" wx:key="id" class="list-item" data-id="{{item.id}}" bindtap="onDetail">
      <view class="li-info"><text class="li-title">{{item.title}}</text><text class="li-sub">{{item.user}} · {{item.time}} · ♥{{item.likes}}</text></view>
      <text class="li-badge {{item.status === '已发布' ? 'badge-green' : 'badge-gray'}}">{{item.status}}</text>
      <text class="li-arrow">›</text>
    </view>
  </view>
</view>