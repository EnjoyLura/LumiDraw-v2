<!-- 编辑风格 -->
<nav-bar title="编辑风格" back />
<view class="admin-page">
  <view class="field-row"><text class="field-label">风格名称</text><input class="field-input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="请输入风格名称" /></view>
  <view class="field-row"><text class="field-label">风格描述</text><input class="field-input" value="{{desc}}" data-field="desc" bindinput="onInput" placeholder="请输入风格描述" /></view>
  <view class="field-row"><text class="field-label">排序权重</text><input class="field-input" type="number" value="{{sort}}" data-field="sort" bindinput="onInput" placeholder="数字越小越靠前" /></view>
  <view class="field-row"><text class="field-label">默认提示词后缀</text><textarea class="field-textarea" value="{{promptSuffix}}" data-field="promptSuffix" bindinput="onInput" placeholder="使用此风格时自动附加的提示词" /></view>
  <view class="action-btn btn-primary" bindtap="onSave">保存</view>
  <view class="action-btn btn-danger">删除风格</view>
</view>