/* 举报页 */
.report-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.page-title { font-size: 30rpx; font-weight: 600; color: #0E1F3A; display: block; margin-bottom: 24rpx; }
.reason-list { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.reason-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; border: 3rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; background: #FFFFFF; transition: all 0.2s; }
.reason-item.active { border-color: #5B9FE8; background: linear-gradient(180deg, rgba(91,159,232,0.06) 0%, transparent 100%); }
.reason-text { font-size: 30rpx; color: #0E1F3A; }
.reason-check { font-size: 36rpx; color: #5B9FE8; font-weight: 700; }
.desc-label { font-size: 30rpx; font-weight: 600; color: #0E1F3A; display: block; margin-bottom: 16rpx; }
.desc-input { width: 100%; min-height: 160rpx; background: #FBFDFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 20rpx 28rpx; font-size: 28rpx; color: #0E1F3A; line-height: 1.6; box-sizing: border-box; margin-bottom: 32rpx; }
.submit-btn { text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 32rpx; font-weight: 700; }
.submit-btn:active { opacity: 0.85; }
