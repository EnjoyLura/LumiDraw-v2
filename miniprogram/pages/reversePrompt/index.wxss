/* 反推提示词页 */
.reverse-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.upload-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 40rpx; text-align: center; margin-bottom: 32rpx; }
.upload-area { border: 4rpx dashed rgba(91,159,232,0.32); border-radius: 32rpx; padding: 80rpx 40rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.upload-icon { font-size: 96rpx; }
.upload-title { font-size: 30rpx; font-weight: 600; color: #0E1F3A; }
.upload-hint { font-size: 24rpx; color: #8497B5; }
.preview-area { margin-bottom: 24rpx; }
.preview-img { width: 100%; height: 400rpx; border-radius: 24rpx; }
.analyze-btn { padding: 24rpx 0; border-radius: 24rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 30rpx; font-weight: 700; margin-top: 32rpx; }
.analyze-btn.loading { background: #E1EBF8; color: #8497B5; }
.analyze-btn:active { opacity: 0.85; }
.section-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; display: block; }
.result-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 28rpx; margin-bottom: 24rpx; }
.result-text { width: 100%; min-height: 200rpx; font-size: 28rpx; color: #0E1F3A; line-height: 1.6; background: none; border: none; padding: 0; }
.result-actions { display: flex; gap: 20rpx; }
.result-btn { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 24rpx; font-size: 28rpx; font-weight: 600; }
.result-btn.secondary { background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.32); color: #0E1F3A; }
.result-btn.primary { background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; }
