/* 全部玩法页 */
.gameplays-page { padding: 24rpx; min-height: 100vh; background: #EEF4FC; }
.gameplay-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.gameplay-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; overflow: hidden; transition: transform 0.2s; }
.gameplay-card:active { transform: scale(0.96); }
.gameplay-cover { width: 100%; aspect-ratio: 1; }
.gameplay-name { font-size: 26rpx; font-weight: 600; color: #0E1F3A; text-align: center; padding: 12rpx 8rpx; display: block; }
