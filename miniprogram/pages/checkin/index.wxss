/* 每日签到页 */
.checkin-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.streak-card { background: linear-gradient(180deg, #E1EBF8, #F5F9FE); border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 48rpx 32rpx; text-align: center; margin-bottom: 32rpx; }
.streak-label { font-size: 26rpx; color: #8497B5; display: block; }
.streak-num-row { display: flex; align-items: baseline; justify-content: center; gap: 8rpx; margin: 16rpx 0 32rpx; }
.streak-num { font-size: 112rpx; font-weight: 700; color: #5B9FE8; font-family: Georgia, serif; line-height: 1; }
.streak-unit { font-size: 40rpx; color: #8497B5; }
.checkin-btn { padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 30rpx; font-weight: 700; }
.checkin-btn:active { opacity: 0.85; }
.checkin-btn.done { background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.14); color: #445876; box-shadow: none; }
.section-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; }
.milestone-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; margin-bottom: 32rpx; }
.milestone-card { background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx 16rpx; text-align: center; transition: all 0.3s; }
.milestone-card.claimed { border-color: rgba(111,212,176,0.3); }
.milestone-card.claimable { border-color: #5B9FE8; }
.ms-days { font-size: 22rpx; color: #8497B5; display: block; }
.ms-reward { font-size: 32rpx; font-weight: 700; color: #5B9FE8; display: block; margin: 8rpx 0; }
.milestone-card.claimed .ms-reward { color: #6FD4B0; }
.ms-status { font-size: 20rpx; font-weight: 600; padding: 4rpx 12rpx; border-radius: 999rpx; display: inline-block; }
.ms-status.claimed { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.ms-status.claimable { background: rgba(91,159,232,0.12); color: #5B9FE8; }
.ms-status.locked { background: rgba(91,159,232,0.06); color: #8497B5; }
.calendar-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 32rpx; }
.cal-month { font-size: 24rpx; color: #8497B5; display: block; margin-bottom: 20rpx; }
.cal-header { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; margin-bottom: 12rpx; }
.cal-weekday { font-size: 22rpx; color: #8497B5; }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4rpx; justify-items: center; }
.cal-empty { width: 72rpx; height: 72rpx; }
.cal-day { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 26rpx; color: #445876; font-weight: 500; position: relative; }
.cal-day.signed { background: #5B9FE8; color: white; font-weight: 600; box-shadow: 0 4rpx 16rpx rgba(91,159,232,0.35); }
.cal-day.today { border: 4rpx solid #5B9FE8; color: #5B9FE8; font-weight: 700; background: rgba(91,159,232,0.12); }
.cal-day.milestone::after { content: '🎁'; position: absolute; top: -8rpx; right: -4rpx; font-size: 18rpx; }
