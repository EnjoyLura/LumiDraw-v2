<!-- 发布作品页 -->
<view class="publish-page">
  <view class="section">
    <text class="section-label">选择作品</text>
    <view class="draft-picker" bindtap="onOpenDraftPicker">
      <block wx:if="{{selectedDraft}}">
        <view class="draft-preview" style="background: {{selectedDraft.color}};"></view>
        <view class="draft-info">
          <text class="draft-title">{{selectedDraft.title}}</text>
          <text class="draft-meta">{{selectedDraft.model}} · {{selectedDraft.ratio}}</text>
        </view>
      </block>
      <block wx:else>
        <view class="draft-empty">
          <text class="de-icon">📁</text>
          <text class="de-text">从草稿箱选择</text>
        </view>
      </block>
      <text class="picker-arrow">›</text>
    </view>
  </view>
  <view class="section">
    <text class="section-label">作品标题</text>
    <input class="field-input" value="{{title}}" maxlength="30" bindinput="onTitleInput" placeholder="给作品起个名字" />
    <text class="field-count">{{titleCount}}/30</text>
  </view>
  <view class="section">
    <text class="section-label">作品描述</text>
    <textarea class="field-textarea" value="{{desc}}" maxlength="200" bindinput="onDescInput" placeholder="介绍一下你的创作灵感吧~" />
    <text class="field-count">{{descCount}}/200</text>
  </view>
  <view class="section">
    <view class="tag-header">
      <text class="section-label">作品标签</text>
      <text class="tag-hint">最多选5个</text>
    </view>
    <view class="tag-grid">
      <view wx:for="{{allTags}}" wx:key="*this"
        class="tag-chip {{selectedTags.indexOf(item) >= 0 ? 'active' : ''}}"
        data-tag="{{item}}" bindtap="onToggleTag">{{item}}</view>
    </view>
  </view>
  <view class="publish-btn" bindtap="onPublish">📤 发布作品</view>
</view>

<bottom-sheet visible="{{showDraftPicker}}" bind:close="onCloseDraftPicker">
  <view class="draft-sheet">
    <view class="sheet-handle"></view>
    <text class="sheet-title">选择草稿作品</text>
    <view class="draft-grid">
      <view wx:for="{{drafts}}" wx:key="id" class="draft-item" data-id="{{item.id}}" bindtap="onSelectDraft">
        <view class="draft-thumb" style="background: {{item.color}};"></view>
        <text class="draft-name">{{item.title}}</text>
      </view>
    </view>
  </view>
</bottom-sheet>
