/* 发布作品页 */
.publish-page { padding: 32rpx; min-height: 100vh; background: #EEF4FC; }
.section { margin-bottom: 36rpx; }
.section-label { font-size: 28rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 16rpx; display: block; }

/* ============ 选择作品 ============ */
.draft-picker {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(91,159,232,0.14);
  border-radius: 28rpx;
  padding: 28rpx;
}

.draft-preview {
  width: 144rpx;
  height: 144rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
}

.draft-empty {
  width: 144rpx;
  height: 144rpx;
  border-radius: 24rpx;
  background: rgba(91,159,232,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.de-icon { font-size: 52rpx; }

.draft-empty-info { flex: 1; min-width: 0; }
.de-title { font-size: 28rpx; font-weight: 600; color: #0E1F3A; display: block; }
.de-hint { font-size: 24rpx; color: #8497B5; display: block; margin-top: 4rpx; }

.draft-info { flex: 1; min-width: 0; }
.draft-title { font-size: 28rpx; font-weight: 700; color: #0E1F3A; display: block; }
.draft-meta { font-size: 24rpx; color: #8497B5; display: block; margin-top: 6rpx; }
.picker-arrow { font-size: 40rpx; color: #8497B5; flex-shrink: 0; }

/* ============ 输入框 ============ */
.field-input {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(91,159,232,0.14);
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #0E1F3A;
  box-sizing: border-box;
}

.field-input.focused {
  border-color: #5B9FE8;
}

.field-count { text-align: right; font-size: 22rpx; color: #8497B5; margin-top: 8rpx; display: block; }

.field-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(91,159,232,0.14);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #0E1F3A;
  line-height: 1.6;
  box-sizing: border-box;
}

.field-textarea.focused {
  border-color: #5B9FE8;
}

/* ============ 标签 ============ */
.tag-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.tag-hint { font-size: 24rpx; color: #8497B5; }
.tag-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }

.tag-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #FBFDFF;
  font-size: 26rpx;
  color: #445876;
  font-weight: 500;
  border: 3rpx solid transparent;
  transition: all 0.25s;
}

.tag-chip.active {
  font-weight: 600;
  border-style: solid;
}

/* ============ 发布按钮 ============ */
.publish-btn { text-align: center; padding: 28rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 32rpx; font-weight: 700; margin-top: 16rpx; }
.publish-btn:active { opacity: 0.85; }

/* ============ 草稿选择弹窗 ============ */
.draft-sheet { padding: 8rpx 40rpx 48rpx; }
.sheet-title { font-size: 32rpx; font-weight: 600; color: #0E1F3A; margin-bottom: 28rpx; display: block; }

.draft-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; }

.draft-item {
  border-radius: 20rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s;
  background: #FBFDFF;
}

.draft-item.selected {
  border-color: #5B9FE8;
  background: linear-gradient(180deg, rgba(91,159,232,0.06) 0%, transparent 100%);
}

.draft-thumb-wrap { position: relative; }
.draft-thumb { width: 100%; aspect-ratio: 1; display: block; }

.draft-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #5B9FE8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
}

.draft-item-info { padding: 12rpx 12rpx 16rpx; }
.draft-name { font-size: 22rpx; color: #445876; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.draft-res { font-size: 20rpx; color: #8497B5; display: block; margin-top: 4rpx; }
