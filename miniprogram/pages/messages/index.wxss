/* 消息中心页 */
.messages-page { padding: 200rpx 32rpx 24rpx; min-height: 100vh; background: #EEF4FC; }
.msg-card { display: flex; align-items: center; gap: 28rpx; background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 28rpx 32rpx; margin-bottom: 20rpx; transition: transform 0.2s; }
.msg-card:active { transform: scale(0.98); }
.msg-icon { width: 96rpx; height: 96rpx; border-radius: 28rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08); }
.msg-icon-text { font-size: 44rpx; color: white; line-height: 1; }
.msg-info { flex: 1; min-width: 0; }
.msg-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6rpx; }
.msg-title { font-size: 30rpx; font-weight: 700; color: #0E1F3A; }
.msg-time { font-size: 24rpx; color: #8497B5; flex-shrink: 0; }
.msg-bottom { display: flex; align-items: center; gap: 16rpx; }
.msg-latest { flex: 1; font-size: 26rpx; color: #445876; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.msg-badge { min-width: 36rpx; height: 36rpx; border-radius: 999rpx; background: #FF6B8A; color: white; font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; flex-shrink: 0; }
