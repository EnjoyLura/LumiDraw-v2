/* 邀请好友页 */
.invite-page { padding: 208rpx 32rpx 32rpx; min-height: 100vh; background: #EEF4FC; }
.invite-hero { background: linear-gradient(135deg, #B8A5E3, #5B9FE8 50%, #6FD4B0); border-radius: 28rpx; padding: 48rpx 32rpx; text-align: center; margin-bottom: 32rpx; }
.hero-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 40rpx; font-weight: 700; color: white; display: block; margin-bottom: 12rpx; }
.hero-desc { font-size: 26rpx; color: rgba(255,255,255,0.85); display: block; }
.code-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; padding: 40rpx 32rpx; text-align: center; margin-bottom: 32rpx; }
.code-label { font-size: 26rpx; color: #8497B5; display: block; margin-bottom: 16rpx; }
.code-value { font-size: 64rpx; font-weight: 700; color: #5B9FE8; letter-spacing: 8rpx; display: block; margin-bottom: 24rpx; }
.code-actions { display: flex; gap: 20rpx; }
.code-btn { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 24rpx; font-size: 28rpx; font-weight: 600; }
.code-btn.secondary { background: #FFFFFF; border: 2rpx solid rgba(91,159,232,0.32); color: #0E1F3A; }
.code-btn.primary { background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; }
.section-title { font-size: 32rpx; font-weight: 700; color: #0E1F3A; margin-bottom: 20rpx; }
.invited-list { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 28rpx; overflow: hidden; margin-bottom: 32rpx; }
.invited-item { display: flex; align-items: center; gap: 20rpx; padding: 24rpx 28rpx; }
.invited-item + .invited-item { border-top: 1rpx solid rgba(91,159,232,0.08); }
.invited-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 28rpx; font-weight: 700; flex-shrink: 0; }
.invited-info { flex: 1; min-width: 0; }
.invited-name { font-size: 30rpx; font-weight: 600; color: #0E1F3A; display: block; }
.invited-date { font-size: 22rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.invited-credits { font-size: 26rpx; font-weight: 600; color: #6FD4B0; background: rgba(111,212,176,0.16); padding: 4rpx 16rpx; border-radius: 999rpx; flex-shrink: 0; }
.rules-card { background: rgba(91,159,232,0.08); border-radius: 24rpx; padding: 28rpx; }
.rules-title { font-size: 26rpx; font-weight: 600; color: #3B7FC8; display: block; margin-bottom: 12rpx; }
.rules-text { font-size: 24rpx; color: #445876; line-height: 1.8; white-space: pre-wrap; }
