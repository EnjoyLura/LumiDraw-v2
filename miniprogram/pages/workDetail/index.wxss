/* 作品详情页样式 */
.detail-page { display: flex; flex-direction: column; height: 100vh; background: #EEF4FC; position: relative; }
.detail-scroll { flex: 1; height: 0; }
.detail-image { width: 100%; aspect-ratio: 4/3; overflow: hidden; }
.image-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.image-title { color: rgba(255,255,255,0.6); font-size: 48rpx; font-weight: 700; text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.3); }
.detail-body { padding: 32rpx; }
.user-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.user-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 32rpx; font-weight: 700; flex-shrink: 0; }
.user-info { flex: 1; min-width: 0; }
.user-name { font-size: 30rpx; font-weight: 700; color: #0E1F3A; display: block; }
.user-meta { font-size: 22rpx; color: #8497B5; display: block; margin-top: 4rpx; }
.follow-btn { padding: 12rpx 32rpx; border-radius: 999rpx; background: #5B9FE8; color: white; font-size: 26rpx; font-weight: 600; flex-shrink: 0; }
.follow-btn:active { opacity: 0.85; }
.follow-btn.following { background: rgba(91,159,232,0.12); color: #8497B5; }
.follow-btn.secondary { background: rgba(91,159,232,0.12); color: #445876; }
.detail-title { font-size: 36rpx; font-weight: 700; color: #0E1F3A; display: block; margin-bottom: 16rpx; }
.detail-desc { font-size: 28rpx; color: #445876; line-height: 1.7; display: block; margin-bottom: 28rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 28rpx; }
.tag { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 999rpx; font-weight: 600; }
.tag.accent { background: rgba(91,159,232,0.12); color: #3B7FC8; }
.tag.mint { background: rgba(111,212,176,0.16); color: #6FD4B0; }
.tag.lavender { background: rgba(184,165,227,0.2); color: #8470C7; }
.tag.peach { background: rgba(255,181,154,0.2); color: #E07A5A; }
.prompt-card { background: #FFFFFF; border: 1rpx solid rgba(91,159,232,0.14); border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx; }
.prompt-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.prompt-label { font-size: 26rpx; font-weight: 600; color: #445876; }
.copy-btn { font-size: 24rpx; color: #5B9FE8; }
.prompt-text { font-size: 26rpx; color: #0E1F3A; line-height: 1.6; word-break: break-all; }
.detail-time { font-size: 24rpx; color: #8497B5; display: block; margin-bottom: 28rpx; }
.stats-row { display: flex; border-top: 1rpx solid rgba(91,159,232,0.14); border-bottom: 1rpx solid rgba(91,159,232,0.14); padding: 24rpx 0; margin-bottom: 28rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 36rpx; font-weight: 700; display: block; }
.stat-label { font-size: 22rpx; color: #8497B5; }
.detail-bottom { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.92); backdrop-filter: blur(20px); border-top: 1rpx solid rgba(91,159,232,0.14); z-index: 80; }
.bottom-row { display: flex; align-items: center; gap: 20rpx; }
.bottom-icon-btn { display: flex; flex-direction: column; align-items: center; gap: 4rpx; min-width: 88rpx; }
.bi-icon { font-size: 48rpx; line-height: 1; }
.bi-label { font-size: 22rpx; color: #8497B5; }
.like-area, .fav-area { display: flex; align-items: center; gap: 8rpx; }
.like-icon { font-size: 56rpx; color: #8497B5; transition: color 0.3s; line-height: 1; }
.like-icon.liked { color: #FFA8B8; animation: detailHeartbeat 0.4s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes detailHeartbeat { 0%{transform:scale(1)} 50%{transform:scale(1.3)} 100%{transform:scale(1)} }
.like-num { font-size: 28rpx; font-weight: 600; color: #8497B5; }
.like-num.liked { color: #FFA8B8; }
.fav-icon { font-size: 56rpx; color: #8497B5; transition: color 0.3s; line-height: 1; }
.fav-icon.liked { color: #FFE08A; animation: detailHeartbeat 0.4s cubic-bezier(0.34,1.56,0.64,1); }
.fav-num { font-size: 28rpx; font-weight: 600; color: #8497B5; }
.fav-num.liked { color: #FFE08A; }
.remake-btn { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 28rpx; background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0); color: white; font-size: 30rpx; font-weight: 700; }
.remake-btn:active { opacity: 0.85; }
