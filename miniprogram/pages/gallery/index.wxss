/* 画廊页样式 */
.gallery-page {
  display: flex;
  flex-direction: column;
  flex: 1;
  height: 0;
  position: relative;
}

/* ============ 整体可滚动 ============ */
.gallery-scroll {
  flex: 1;
  height: 0;
}

/* ============ 头部区域（随页面滚动） ============ */
.gallery-header {
  padding-bottom: 16rpx;
  transition: background 0.3s;
}

.gallery-topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 32rpx;
}

.topbar-btn {
  padding: 8rpx;
}

.topbar-icon {
  font-size: 44rpx;
  color: #0E1F3A;
  line-height: 1;
}

.topbar-spacer {
  flex: 1;
}

.bg-picker-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(91, 159, 232, 0.12);
}

.bg-picker-icon {
  font-size: 28rpx;
}

.bg-picker-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #5B9FE8;
}

/* 用户信息 */
.user-row {
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  padding: 24rpx 32rpx 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
  width: 144rpx;
  height: 144rpx;
}

.avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 56rpx;
  font-weight: 700;
}

.avatar-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #5B9FE8;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #EEF4FC;
  color: white;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
  padding: 0;
  box-sizing: border-box;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0E1F3A;
  display: block;
}

.user-id {
  font-size: 26rpx;
  color: #8497B5;
  margin-top: 6rpx;
  display: block;
}

/* 性别标签（一体化） */
.gender-tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  margin-top: 6rpx;
}

.gender-tag.female {
  background: rgba(255, 168, 184, 0.22);
  color: #FFA8B8;
}

.gender-tag.male {
  background: rgba(91, 159, 232, 0.12);
  color: #5B9FE8;
}

.user-signature {
  font-size: 28rpx;
  color: #445876;
  line-height: 1.5;
  padding: 20rpx 32rpx 0;
  display: block;
}

.user-tags {
  padding: 16rpx 32rpx 0;
}

.user-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(184, 165, 227, 0.2);
  color: #8470C7;
}

/* 统计 + 编辑 */
.stats-row {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.stats-list {
  flex: 1;
  display: flex;
  gap: 56rpx;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 26rpx;
  color: #8497B5;
}

.edit-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  background: #5B9FE8;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.edit-btn:active {
  background: #4A8FD8;
}

/* ============ Tab + 管理 ============ */
.tab-manage-row {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.gallery-tabs {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 40rpx;
  position: relative;
  padding-bottom: 12rpx;
}

.gallery-tab {
  font-size: 26rpx;
  font-weight: 500;
  color: #8497B5;
  position: relative;
  padding-bottom: 12rpx;
  transition: color 0.3s;
  flex-shrink: 0;
  line-height: 1;
}

.gallery-tab.active {
  font-weight: 700;
  color: #5B9FE8;
}

.gallery-tab-indicator {
  position: absolute;
  bottom: 0;
  width: 28rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #5B9FE8;
  opacity: 0;
  transition: left 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.manage-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  color: #8497B5;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.manage-btn.active {
  color: #5B9FE8;
  background: rgba(91, 159, 232, 0.12);
}

.manage-icon {
  font-size: 32rpx;
}

/* ============ Tab 加载 spinner ============ */
.tab-loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.tab-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 5rpx solid rgba(91, 159, 232, 0.15);
  border-top-color: #5B9FE8;
  border-radius: 50%;
  animation: tabSpin 0.7s linear infinite;
}

@keyframes tabSpin {
  to { transform: rotate(360deg); }
}

/* 瀑布流滑入动画 */
@keyframes wfSlideLeft {
  from { opacity: 0; transform: translateX(-60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes wfSlideRight {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.wf-slide-left {
  animation: wfSlideLeft 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

.wf-slide-right {
  animation: wfSlideRight 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}

/* ============ 生成中任务 ============ */
.gen-tasks {
  padding: 0 24rpx;
  margin-bottom: 12rpx;
}

.gen-task-card {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 2rpx solid rgba(91, 159, 232, 0.12);
  margin-bottom: 12rpx;
}

.gen-task-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent 25%, rgba(91, 159, 232, 0.06) 50%, transparent 75%);
  background-size: 200% 100%;
  animation: taskShimmer 2s ease infinite;
}

@keyframes taskShimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.gen-task-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 20rpx;
}

.gen-task-info {
  flex: 1;
  min-width: 0;
}

.gen-task-prompt {
  font-size: 26rpx;
  font-weight: 600;
  color: #0E1F3A;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.gen-task-meta {
  font-size: 22rpx;
  color: #8497B5;
  margin-top: 4rpx;
  display: block;
}

.gen-task-pct {
  font-size: 36rpx;
  font-weight: 700;
  color: #5B9FE8;
}

.gen-task-bar {
  height: 8rpx;
  background: rgba(91, 159, 232, 0.1);
  overflow: hidden;
}

.gen-task-bar-fill {
  height: 100%;
  background: linear-gradient(135deg, #5B9FE8, #7BC4F0, #6FD4B0);
  transition: width 0.4s ease;
}

/* ============ 作品区域 ============ */
.gallery-waterfall {
  padding: 0 24rpx;
}

.gallery-empty {
  padding-top: 80rpx;
}

/* ============ 管理底部栏（动画滑入） ============ */
.manage-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 32rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(91, 159, 232, 0.14);
  z-index: 80;
  transform: translateY(100%);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease;
  pointer-events: none;
}

.manage-bar.show {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.manage-count {
  flex: 1;
  font-size: 26rpx;
  color: #445876;
}

.manage-select-all {
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  background: rgba(91, 159, 232, 0.12);
  font-size: 26rpx;
  font-weight: 600;
  color: #5B9FE8;
}

.manage-select-all:active {
  background: rgba(91, 159, 232, 0.2);
}

.manage-delete {
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
  background: #FFA8B8;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  opacity: 0.5;
  transition: opacity 0.3s, background 0.3s;
}

.manage-delete.active {
  opacity: 1;
  background: #FF6B8A;
}

.manage-delete.active:active {
  background: #E05A7A;
}

/* ============ 悬浮发布按钮 ============ */
.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: 220rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(91, 159, 232, 0.85), rgba(70, 130, 210, 0.9));
  backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(91, 159, 232, 0.35);
  z-index: 75;
  transition: transform 0.2s;
}

.publish-fab:active {
  transform: scale(0.93);
}

.fab-icon {
  font-size: 48rpx;
  color: white;
  line-height: 1;
}

/* ============ 背景选择弹窗 ============ */
.bg-picker {
  padding: 16rpx 40rpx 48rpx;
}

.bg-picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0E1F3A;
  margin-bottom: 28rpx;
}

.bg-color-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx;
}

.bg-color-item {
  aspect-ratio: 1;
  border-radius: 24rpx;
  border: 4rpx solid rgba(91, 159, 232, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.bg-color-item.selected {
  border-color: #5B9FE8;
}

.bg-check {
  font-size: 36rpx;
  color: #5B9FE8;
  font-weight: 700;
}

.bg-gradient-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.bg-gradient-item {
  aspect-ratio: 1.2;
  border-radius: 24rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 12rpx;
  position: relative;
  transition: all 0.2s;
}

.bg-gradient-item.selected {
  border-color: #5B9FE8;
}

.bg-gradient-name {
  font-size: 20rpx;
  color: #8497B5;
}

/* ============ 左抽屉 ============ */
.drawer-header {
  padding: 180rpx 40rpx 0;
  background: linear-gradient(180deg, #E1EBF8 0%, #F5F9FE 100%);
  border-bottom: 1rpx solid rgba(91, 159, 232, 0.14);
  padding-bottom: 48rpx;
}

.drawer-user-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 40rpx;
}

.drawer-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.drawer-user-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.drawer-user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #0E1F3A;
}

.drawer-credits {
  font-size: 32rpx;
  color: #8497B5;
}

.credits-num {
  color: #5B9FE8;
  font-weight: 700;
}

.credits-label {
  color: #8497B5;
}

.drawer-quick {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.drawer-quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.dq-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dq-icon-text {
  color: white;
  font-size: 36rpx;
  line-height: 1;
}

.dq-text {
  font-size: 24rpx;
  color: #445876;
}

.drawer-menu {
  padding: 24rpx 0;
  flex: 1;
}

.drawer-menu-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 26rpx 40rpx;
  position: relative;
}

.drawer-menu-item:active {
  background: rgba(91, 159, 232, 0.06);
}

.dm-icon {
  font-size: 44rpx;
  width: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.dm-text {
  font-size: 30rpx;
  color: #0E1F3A;
  flex: 1;
}

.dm-arrow {
  font-size: 36rpx;
  color: #8497B5;
  flex-shrink: 0;
}

.dm-badge {
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #FFA8B8;
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  flex-shrink: 0;
}
