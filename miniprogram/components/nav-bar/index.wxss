.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(238, 244, 252, 0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1rpx solid rgba(91, 159, 232, 0.10);
}

.nav-bar.transparent {
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom: none;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-back {
  position: absolute;
  left: 12rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.back-arrow {
  font-size: 52rpx;
  color: #0E1F3A;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0E1F3A;
}

.nav-placeholder {
  width: 100%;
  flex-shrink: 0;
}
