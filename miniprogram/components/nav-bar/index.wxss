.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, #E8EFF8 0%, rgba(238, 244, 252, 0.92) 100%);
  border-bottom: 1rpx solid rgba(91, 159, 232, 0.08);
}

.nav-bar.transparent {
  background: transparent;
  border-bottom: none;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.nav-back {
  position: absolute;
  left: 12rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.back-arrow {
  font-size: 52rpx;
  color: #0E1F3A;
  font-weight: 300;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #0E1F3A;
}

.nav-placeholder {
  width: 100%;
  flex-shrink: 0;
}
