<!-- 空状态组件 -->
<view class="empty-state">
  <view class="empty-icon" style="background: {{iconBg}};">
    <text class="empty-icon-char" style="color: {{iconColor}};">{{icon}}</text>
  </view>
  <text class="empty-text">{{text}}</text>
  <text wx:if="{{subText}}" class="empty-sub">{{subText}}</text>
  <view wx:if="{{buttonText}}" class="empty-btn" bindtap="onAction">
    <text>{{buttonText}}</text>
  </view>
</view>
