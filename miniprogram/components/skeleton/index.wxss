/* 骨架屏组件 */
.skeleton {
  background: linear-gradient(90deg, #E1EBF8 25%, #F5F9FE 50%, #E1EBF8 75%);
  background-size: 200% 100%;
  animation: shimmer 2.5s ease-in-out infinite;
  border-radius: 16rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 首页骨架 */
.skeleton-home {
  padding: 0;
}

.sk-banner {
  height: 300rpx;
  border-radius: 40rpx;
  margin: 0 32rpx 32rpx;
}

.sk-section {
  height: 36rpx;
  width: 160rpx;
  margin: 0 32rpx 24rpx;
  border-radius: 8rpx;
}

.sk-gameplay {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 36rpx;
}

.sk-gp-item {
  width: 160rpx;
  height: 200rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.sk-wf {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.sk-wf-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-wf-item {
  border-radius: 40rpx;
}

/* 列表骨架 */
.skeleton-list {
  padding: 0 32rpx;
}

.sk-list-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(91, 159, 232, 0.08);
}

.sk-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sk-list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sk-line {
  height: 32rpx;
  border-radius: 8rpx;
}
