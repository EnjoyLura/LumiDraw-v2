<!-- 瀑布流组件 -->
<view class="waterfall">
  <!-- 左列 -->
  <view class="waterfall-col" id="col-left">
    <block wx:for="{{leftItems}}" wx:key="id">
      <view class="wf-item" data-id="{{item.id}}" bindlongpress="onItemLongPress">
        <view class="card" style="{{manageMode ? 'position:relative;' : ''}}">
          <view wx:if="{{manageMode}}" class="manage-check {{selectedMap[item.id || item._id] ? 'checked' : ''}}">
            <text wx:if="{{selectedMap[item.id || item._id]}}">✓</text>
          </view>
          <view wx:if="{{showPublished && item.status === 'published'}}" class="published-badge">
            <text class="badge-icon">✓</text>
            <text class="badge-text">已发布</text>
          </view>
          <view class="card-img-wrap" style="aspect-ratio: {{item._aspectRatio}};" data-id="{{item.id}}" bindtap="onItemTap">
            <image
              wx:if="{{item.imageUrl || (item.imageUrls && item.imageUrls[0])}}"
              class="card-img {{item._imgLoaded ? 'loaded' : ''}}"
              src="{{item.imageUrl || item.imageUrls[0]}}"
              mode="aspectFill"
              lazy-load
              bindload="onImageLoad"
              data-id="{{item.id}}"
            />
            <view wx:else class="card-color-placeholder" style="background: {{item._cardColor || 'linear-gradient(135deg, #E1EBF8, #F5F9FE)'}};">
              <text class="placeholder-label">{{item._displayTitle}}</text>
            </view>
          </view>
          <view class="card-info">
            <text class="card-title ellipsis">{{item._displayTitle}}</text>
            <view class="card-meta">
              <view class="card-user" catchtap="onUserTap" data-user-id="{{item.userId}}">
                <view class="user-avatar" style="background: {{item._userColor}};">
                  <text>{{item._userAvatarText}}</text>
                </view>
                <text class="user-name ellipsis">{{item._userName}}</text>
              </view>
              <view class="card-like" catchtap="onLikeTap" data-id="{{item.id}}">
                <text class="like-icon {{item._liked ? 'liked' : ''}}">♥</text>
                <text class="like-count {{item._liked ? 'liked' : ''}}">{{item.likes}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
  <!-- 右列 -->
  <view class="waterfall-col" id="col-right">
    <block wx:for="{{rightItems}}" wx:key="id">
      <view class="wf-item" data-id="{{item.id}}" bindlongpress="onItemLongPress">
        <view class="card" style="{{manageMode ? 'position:relative;' : ''}}">
          <view wx:if="{{manageMode}}" class="manage-check {{selectedMap[item.id || item._id] ? 'checked' : ''}}">
            <text wx:if="{{selectedMap[item.id || item._id]}}">✓</text>
          </view>
          <view wx:if="{{showPublished && item.status === 'published'}}" class="published-badge">
            <text class="badge-icon">✓</text>
            <text class="badge-text">已发布</text>
          </view>
          <view class="card-img-wrap" style="aspect-ratio: {{item._aspectRatio}};" data-id="{{item.id}}" bindtap="onItemTap">
            <image
              wx:if="{{item.imageUrl || (item.imageUrls && item.imageUrls[0])}}"
              class="card-img {{item._imgLoaded ? 'loaded' : ''}}"
              src="{{item.imageUrl || item.imageUrls[0]}}"
              mode="aspectFill"
              lazy-load
              bindload="onImageLoad"
              data-id="{{item.id}}"
            />
            <view wx:else class="card-color-placeholder" style="background: {{item._cardColor || 'linear-gradient(135deg, #E1EBF8, #F5F9FE)'}};">
              <text class="placeholder-label">{{item._displayTitle}}</text>
            </view>
          </view>
          <view class="card-info">
            <text class="card-title ellipsis">{{item._displayTitle}}</text>
            <view class="card-meta">
              <view class="card-user" catchtap="onUserTap" data-user-id="{{item.userId}}">
                <view class="user-avatar" style="background: {{item._userColor}};">
                  <text>{{item._userAvatarText}}</text>
                </view>
                <text class="user-name ellipsis">{{item._userName}}</text>
              </view>
              <view class="card-like" catchtap="onLikeTap" data-id="{{item.id}}">
                <text class="like-icon {{item._liked ? 'liked' : ''}}">♥</text>
                <text class="like-count {{item._liked ? 'liked' : ''}}">{{item.likes}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
