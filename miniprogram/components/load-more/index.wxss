/* 加载更多组件 */
.load-more {
  width: 100%;
  padding: 36rpx 0 20rpx;
  text-align: center;
}

.load-more-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.load-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(91, 159, 232, 0.15);
  border-top-color: #5B9FE8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-text {
  font-size: 24rpx;
  color: #8497B5;
}

.load-more-end {
  padding: 8rpx 0;
}

.load-end-text {
  font-size: 24rpx;
  color: #8497B5;
  opacity: 0.6;
}
