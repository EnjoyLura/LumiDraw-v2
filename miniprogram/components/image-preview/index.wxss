/* 图片预览组件 */
.preview-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.92);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.preview-overlay.show {
  opacity: 1;
  visibility: visible;
}

.preview-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-height: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.preview-img {
  max-width: 100%;
  max-height: 70vh;
  border-radius: 24rpx;
  transform: scale(0.8);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;
}

.preview-img.show {
  transform: scale(1);
  opacity: 1;
}

.preview-save-btn {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.preview-save-btn:active {
  background: rgba(255, 255, 255, 0.25);
}

.save-icon {
  font-size: 36rpx;
}
